# ===========================================
# NEON.TECH (SERVERLESS POSTGRESQL)
# Get from: https://console.neon.tech → Project → Connection Details
# Use the pooled connection string for serverless (Prisma from serverless)
# ===========================================
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/repurposeai?sslmode=require"

# ===========================================
# SUPABASE (Legacy - being migrated away)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# MORPHLLM AI (OpenAI-compatible)
# Get your API key from: https://morphllm.com
# Model: morph-glm52-744b
# ===========================================
AI_API_KEY=sk-your-morphllm-api-key
AI_BASE_URL=https://api.morphllm.com/v1
AI_MODEL=morph-glm52-744b

# ===========================================
# STRIPE
# Get from: https://dashboard.stripe.com/test/apikeys
# Products: Create "Starter" ($19/mo) and "Pro" ($49/mo) → copy Price IDs
# Webhook: Run `stripe listen --forward-to localhost:3000/api/billing/webhook`
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ===========================================
# SENTRY
# Get from: https://sentry.io → Settings → Projects → Client Keys (DSN)
# ===========================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ===========================================
# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ===========================================
JWT_SECRET=your-256-bit-secret-change-me-in-production

# ===========================================
# UPSTASH / REDIS
# Get from: https://console.upstash.com → Redis Database → REST API
# ===========================================
REDIS_URL=https://your-redis-url.upstash.io
REDIS_TOKEN=your-redis-token

# ===========================================
# CRON SECRET
# Shared secret between Vercel Cron and the /api/cron/process-posts endpoint
# ===========================================
CRON_SECRET=your-cron-secret-change-me

# ===========================================
# RESEND
# Get from: https://resend.com → API Keys
# ===========================================
RESEND_API_KEY=re_your-resend-api-key

# ===========================================
# CLOUDINARY
# Get from: https://cloudinary.com → Dashboard
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# APP
# Change NEXT_PUBLIC_APP_URL to your domain after deploying to Vercel
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RepurposeAI
